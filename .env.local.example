# ============================================================
# AgencyOS / MeetingOS — Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.local.example .env.local
#
# Quick start:
# 1. Create a free Supabase project at https://supabase.com
# 2. Run the migrations from supabase/migrations/
# 3. Get your API keys from Supabase dashboard → Project Settings → API
# ============================================================

# ─── Supabase (Required) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI Service (Google Gemini — FREE tier, no credit card needed) ───
# Get a free API key: https://aistudio.google.com/apikey
# 1500+ requests/day on the free tier! No credit card required.
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# ─── AI Service (OpenAI — optional fallback) ──────────────
# Only needed if you want OpenAI as a fallback for Gemini
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ─── Site URL (Required for auth redirects) ────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Optional: Mock Mode (runs without any services)
# ============================================================
# The app works in "mock mode" when environment variables are
# missing. All data will be local/mock data with console logs.
# Great for UI development!
